# Environment variables — copy to .env and fill in
# Never commit .env to git

# ── API settings ───────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development   # development | production

# CORS — comma-separated list of allowed frontend origins.
# Defaults to localhost dev servers when not set.
# Set this in Railway/Render/Fly env vars for production.
# ALLOWED_ORIGINS=https://your-app.up.railway.app,https://www.yoursite.com

# Max upload size in MB
MAX_UPLOAD_MB=50

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default — zero config, created automatically on first run):
# DATABASE_URL=sqlite:///./pdf_to_qbo.db
# PostgreSQL (recommended for production, e.g. Railway Postgres add-on):
# DATABASE_URL=postgresql://user:password@host:5432/pdf_to_qbo

# ── Authentication ─────────────────────────────────────────────────────────────
# Path to the SQLite database that stores API keys and usage.
# Default: data/api_keys.db  (created automatically on first run)
# DB_PATH=data/api_keys.db

# Admin API key — bypasses all quota checks.  Keep this secret.
# Generate one with:  python3 -c "import secrets; print('qbo_admin_' + secrets.token_hex(32))"
# ADMIN_API_KEY=qbo_admin_...

# ── Stripe billing ─────────────────────────────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from the Stripe dashboard → Webhooks → your endpoint
# STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for recurring subscription products (monthly billing)
# Create products at https://dashboard.stripe.com/products and paste the price IDs here
# STRIPE_PRICE_STARTER=price_...    # $9/month  — 100 conversions
# STRIPE_PRICE_PRO=price_...        # $29/month — unlimited conversions

# ── Anthropic API ──────────────────────────────────────────────────────────────
# Enables LLM fallback parser for unknown banks / changed layouts, and OCR.
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# (Optional) Override the model used by the LLM parser
# Defaults to claude-3-5-haiku-20241022 (fast + cheap)
# PDF_PARSER_LLM_MODEL=claude-3-5-haiku-20241022
