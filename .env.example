# Environment variables — copy to .env and fill in
# Never commit .env to git

# API settings
PORT=8000
ENVIRONMENT=development   # development | production

# CORS — comma-separated list of allowed frontend origins
# Defaults to localhost dev servers when not set.
# Set this in Railway/Render/Fly env vars for production.
# ALLOWED_ORIGINS=https://your-app.up.railway.app,https://www.yoursite.com

# Stripe (for billing — add later)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Max file size in MB
MAX_UPLOAD_MB=50

# Anthropic API — enables LLM fallback for unknown banks / changed layouts
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# (Optional) Override the model used by the LLM parser
# Defaults to claude-3-5-haiku-20241022 (fast + cheap)
# PDF_PARSER_LLM_MODEL=claude-3-5-haiku-20241022
